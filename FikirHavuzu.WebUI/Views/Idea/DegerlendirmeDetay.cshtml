@model FikirHavuzu.Entities.Idea

<div class="container py-5">

    <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
            <h2 class="fw-800 mb-0">@Model.Title</h2>
            <p class="opacity-75 mb-0">Fikrinize yapılan tüm topluluk değerlendirmeleri</p>
        </div>
        <div class="card-body p-4 bg-light">
            <p class="fs-5 text-muted italic">"@Model.Description"</p>
        </div>
    </div>

    <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-chat-left-text-fill text-primary me-2"></i>Tüm Değerlendirmeler
    </h4>

    <div class="row g-4">
        @if (ViewBag.Evaluations != null)
        {
            @foreach (var eval in ViewBag.Evaluations)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 transition-all hover-up">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                @{
                                    var statusClass = eval.Status == "Onaylandı" ? "bg-success" :
                                    eval.Status == "Reddedildi" ? "bg-danger" : "bg-info";
                                }
                                <span class="badge @statusClass text-white rounded-pill px-3 shadow-sm" style="font-size: 0.7rem;">
                                    <i class="bi bi-check-circle me-1"></i> @eval.Status
                                </span>
                                
                                <small class="text-muted">@eval.Date.ToString("dd.MM.yyyy")</small>
                            </div>

                            <div class="mb-3">
                                <span class="badge bg-warning text-dark fs-6 rounded-pill px-3 shadow-sm">
                                    <i class="bi bi-star-fill me-1"></i> +@eval.Score Puan
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-calendar-event me-1"></i>@eval.Date.ToString("dd.MM.yyyy")
                                </small>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm"
                                     style="width: 40px; height: 40px; font-size: 0.9rem; font-weight: 800;">
                                    @eval.UserName.Substring(0,1).ToUpper()
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">@eval.UserName</h6>
                                    <small class="text-muted" style="font-size: 0.7rem;">Ekip Üyesi</small>
                                </div>
                            </div>

                            <div class="p-3 bg-light rounded-3 border-start border-primary border-4 shadow-xs">
                                <p class="mb-0 small text-dark italic">
                                    <i class="bi bi-quote opacity-50 me-1 text-primary"></i>
                                    @(string.IsNullOrEmpty(eval.Description) ? "Yorum belirtilmedi." : eval.Description)
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="display-4 text-muted opacity-25 mb-3"><i class="bi bi-chat-dots"></i></div>
                <p class="text-muted">Bu fikir henüz kimse tarafından değerlendirilmemiş.</p>
            </div>
        }

        <style>
            .hover-up:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(9, 132, 227, 0.1) !important;
            }

            .shadow-xs {
                box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
            }

            .italic {
                font-style: italic;
            }
        </style>