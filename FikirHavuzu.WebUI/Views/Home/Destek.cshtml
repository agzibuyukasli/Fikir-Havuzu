@{
    ViewData["Title"] = "Teknik Destek";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header p-5 text-center text-white border-0" 
                     style="background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);">
                    <i class="bi bi-headset display-1 mb-3"></i>
                    <h2 class="fw-800">Teknik Destek</h2>
                    <p class="opacity-75 mb-0">Bir sorun mu yaşıyorsunuz? Size yardımcı olmak için buradayız.</p>
                </div>
                <div class="card-body p-5">
                    <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-4">
                        <div class="icon-box bg-primary text-white me-3 shadow-sm">
                            <i class="bi bi-envelope-fill"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">E-Posta Adresimiz</h6>
                            <span class="text-muted small">destek@fikirhavuzu.com</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-4">
                        <div class="icon-box bg-success text-white me-3 shadow-sm">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Telefon Hattı</h6>
                            <span class="text-muted small">0850 123 45 67</span>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-4 text-uppercase fw-bold" style="letter-spacing: 1px;">Sosyal Medyada Biz</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a href="#" class="btn btn-outline-primary rounded-circle"><i class="bi bi-linkedin"></i></a>
                            <a href="#" class="btn btn-outline-info rounded-circle"><i class="bi bi-twitter"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .icon-box { width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 15px; font-size: 1.2rem; }
</style>