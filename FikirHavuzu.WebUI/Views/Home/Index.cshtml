@model FikirHavuzu.WebUI.Models.DashboardViewModel

@{
    var totalUsers = Model?.TotalUsers ?? 0;
    var latestIdea = Model?.LatestIdeaTitle ?? "Henüz Fikir Yok";
    var activeName = ViewBag.MostActiveUser ?? "Henüz Yok";
    var ideaCount = ViewBag.IdeaCount ?? 0;
}

<div class="container-fluid px-md-5 py-5">
    <div class="text-center mb-5 animate__animated animate__fadeInDown">
        <h1 class="display-3 fw-800 text-dark mb-2">Sistem Genel Özeti</h1>
        <p class="fs-4 text-muted opacity-75">Fikir Havuzu ekosistemindeki tüm veriler ve canlı istatistikler.</p>
        <div class="mx-auto mt-3 shadow-sm underline-premium"></div>
    </div>

    <div class="row g-4 mb-5 justify-content-center animate__animated animate__fadeInUp">
        
        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card border-0 shadow-lg rounded-5 h-100 dash-card-large border-bottom border-danger border-5">
                <div class="card-body p-5 text-center">
                    <div class="icon-circle-large bg-danger-subtle text-danger mb-4 mx-auto shadow-sm">
                        <i class="bi bi-fire"></i>
                    </div>
                    <h5 class="text-muted fw-bold text-uppercase small mb-2" style="letter-spacing: 1px;">En Aktif Üye</h5>
                    <h3 class="fw-800 text-dark mb-0">@activeName</h3>
                    <div class="mt-4">
                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-4 py-2 fs-6">Sistem Lideri</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card border-0 shadow-lg rounded-5 h-100 dash-card-large border-bottom border-primary border-5">
                <div class="card-body p-5 text-center">
                    <div class="icon-circle-large bg-primary-subtle text-primary mb-4 mx-auto shadow-sm">
                        <i class="bi bi-lightbulb-fill"></i>
                    </div>
                    <h5 class="text-muted fw-bold text-uppercase small mb-2" style="letter-spacing: 1px;">Toplam Fikir</h5>
                    <h2 class="display-4 fw-800 text-primary mb-0">@ideaCount</h2>
                </div>
            </div>
        </div>


        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card border-0 shadow-lg rounded-5 h-100 dash-card-large border-bottom border-info border-5">
                <div class="card-body p-5 text-center">
                    <div class="icon-circle-large bg-info-subtle text-info mb-4 mx-auto shadow-sm">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5 class="text-muted fw-bold text-uppercase small mb-2" style="letter-spacing: 1px;">Kullanıcı Sayısı</h5>
                    <h2 class="display-4 fw-800 text-info mb-0">@totalUsers</h2>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card border-0 shadow-lg rounded-5 h-100 dash-card-large text-white bg-premium-gradient">
                <div class="card-body p-5 text-center d-flex flex-column justify-content-center">
                    <div class="icon-circle-large bg-white bg-opacity-20 text-primary mb-4 mx-auto shadow-sm border border-white border-opacity-25">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <h5 class="fw-bold text-uppercase small mb-2 opacity-75" style="letter-spacing: 1px;">Son Paylaşım</h5>
                    <h4 class="fw-800 mb-0 text-truncate-2 px-2">@latestIdea</h4>
                    <div class="mt-4 small opacity-75 fw-bold"><i class="bi bi-clock-history me-1"></i>
                    <p>
                        <i class="bi bi-clock"></i> 
                        @{
                            var timeSpan = DateTime.Now - Model.LastIdeaDate;

                            if (Model.LastIdeaDate.Year < 2000) 
                            {
                                <span>Tarih bilgisi alınamadı</span>
                            }
                            else if (timeSpan.TotalDays >= 1)
                            {
                                @($"{(int)timeSpan.TotalDays} gün önce paylaşıldı")
                            }
                            else if (timeSpan.TotalHours >= 1)
                            {
                                @($"{(int)timeSpan.TotalHours} saat önce paylaşıldı")
                            }
                            else
                            {
                                @("Şimdi paylaşıldı")
                            }
                        }
                    </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <div class="d-flex flex-wrap gap-4 justify-content-center">
            <a asp-controller="Idea" asp-action="Index" class="btn btn-primary btn-xxl px-5 py-3 rounded-pill fw-800 shadow-lg hover-up">
                <i class="bi bi-grid-fill me-2"></i> FİKİRLERİ YÖNET
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-dark btn-xxl px-5 py-3 rounded-pill fw-800 shadow-sm hover-up">
                    <i class="bi bi-people-fill me-2"></i> PERSONEL LİSTESİ
                </a>
            }
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f4f8 !important; }
    .fw-800 { font-weight: 800; }
    
    .underline-premium {
        width: 100px;
        height: 7px;
        background: linear-gradient(90deg, #0984e3, #00cec9);
        border-radius: 50px;
    }

    .bg-premium-gradient {
        background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%) !important;
    }

    .dash-card-large {
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: white;
        min-height: 350px;
    }

    .dash-card-large:hover {
        transform: translateY(-15px);
        box-shadow: 0 25px 50px rgba(0,0,0,0.15) !important;
    }

    .icon-circle-large {
        width: 90px;
        height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 25px;
        font-size: 2.5rem;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .btn-xxl {
        font-size: 1.1rem;
        letter-spacing: 0.5px;
    }

    .hover-up:hover {
        transform: scale(1.05);
        transition: 0.3s;
    }

    .bg-primary-subtle { background-color: #e3f2fd; }
    .bg-danger-subtle { background-color: #ffebee; }
    .bg-info-subtle { background-color: #e0f7fa; }
</style>