@model FikirHavuzu.Entities.User

@{
    string rankName = "Yeni Fikirci";
    string rankClass = "bg-info";
    if (Model.TotalScore >= 100) { rankName = "Usta Geliştirici"; rankClass = "bg-primary"; }
    else if (Model.TotalScore >= 50) { rankName = "Fikir Mimarı"; rankClass = "bg-success"; }
}

<div class="container-fluid px-md-5 mt-4 mb-5">
    <div class="row mb-4 mx-0">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-link text-decoration-none p-0 text-muted fw-bold">
                <i class="bi bi-arrow-left"></i> Personel Listesine Dön
            </a>
        </div>
    </div>

    <div class="row mx-0 g-4 align-items-stretch">

        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden h-100">
                <div class="p-5 text-center text-white"
                     style="background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);">
                    <div class="bg-white text-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow mb-3"
                         style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: 800;">
                        @Model.FirstName[0]@Model.LastName[0]
                    </div>
                    <h2 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h2>
                    <span class="badge @rankClass text-white rounded-pill px-3 shadow-sm">@rankName</span>
                </div>
                <div class="card-body p-4">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                            <span class="text-muted small fw-bold text-uppercase">E-Posta</span>
                            <span class="fw-bold text-break ms-2">@Model.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                            <span class="text-muted small fw-bold text-uppercase">Toplam Puan</span>
                            <span class="badge bg-warning text-dark fs-6 p-2 rounded-pill">@Model.TotalScore Puan</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                            <span class="text-muted small fw-bold text-uppercase">Durum</span>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success px-3 py-1 rounded-pill">Aktif Üye</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-1 rounded-pill">Pasif</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-8 d-flex flex-column">

            @if (User.IsInRole("Admin"))
            {
                <div class="card border-0 shadow-lg rounded-4 p-4 mb-4 border-start border-primary border-5">
                    <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-shield-lock-fill text-primary"></i> Yönetimsel İşlemler</h4>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-4 rounded-4 border h-100 @(Model.IsActive ? "bg-light" : "bg-danger-subtle")">
                                <h5 class="fw-bold">Hesap Durumu</h5>
                                <p class="small text-muted mb-4">Kullanıcının sisteme giriş yetkisini tek tıkla kapatıp açabilirsin.</p>
                                <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="btn @(Model.IsActive ? "btn-danger" : "btn-success") w-100 rounded-pill fw-bold py-2 shadow-sm">
                                        <i class="bi @(Model.IsActive ? "bi-person-x" : "bi-person-check") me-2"></i> 
                                        @(Model.IsActive ? "Hesabı Askıya Al" : "Hesabı Aktifleştir")
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-4 rounded-4 border bg-light h-100">
                                <h5 class="fw-bold">Veri Güncelleme</h5>
                                <p class="small text-muted mb-4">Rol değişikliği veya isim düzeltme gibi işlemleri buradan yap.</p>
                                <div class="d-grid gap-2">
                                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                        <i class="bi bi-pencil-square me-2"></i> Bilgileri Düzenle
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row g-4 flex-grow-1">
                <div class="col-md-6 text-center">
                    <div class="card border-0 shadow-lg rounded-4 p-4 h-100 d-flex flex-column justify-content-center transition-hover bg-white">
                        <div class="text-primary display-3 mb-2"><i class="bi bi-lightbulb-fill"></i></div>
                        <div class="display-5 fw-bold mb-0">@(Model.Ideas?.Count ?? 0)</div>
                        <div class="text-muted fw-bold text-uppercase small">Üretilen Fikir Sayısı</div>
                    </div>
                </div>

                <div class="col-md-6 text-center">
                    <div class="card border-0 shadow-lg rounded-4 p-4 h-100 d-flex flex-column justify-content-center transition-hover bg-white">
                        <div class="text-warning display-3 mb-2"><i class="bi bi-trophy-fill"></i></div>
                        <div class="display-5 fw-bold mb-0">#@(ViewBag.GeneralRank ?? 0)</div>
                        <div class="text-muted fw-bold text-uppercase small">Genel Sıralama</div>
                    </div>
                </div>
            </div>

        </div> 
    </div> 
</div>

<style>
    body { background-color: #f8fafd !important; }
    .transition-hover { transition: all 0.3s ease; border: 1px solid transparent; }
    .transition-hover:hover { transform: translateY(-8px); border-color: #0984e3; box-shadow: 0 1rem 3rem rgba(9, 132, 227, 0.1) !important; }
</style>