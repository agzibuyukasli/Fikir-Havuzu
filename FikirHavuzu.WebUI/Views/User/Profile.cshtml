@model FikirHavuzu.Entities.User

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="p-4 text-white text-center" style="background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);">
                    <h3 class="fw-bold mb-0"><i class="bi bi-person-gear"></i> Profil Ayarları</h3>
                    <p class="opacity-75 small">Kişisel bilgilerinizi buradan güncelleyebilirsiniz.</p>
                </div>

                <div class="card-body p-5">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                        </div>
                    }

                    <form asp-action="Profile" method="post">
                        <input type="hidden" asp-for="Id" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Adınız</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person text-primary"></i></span>
                                <input asp-for="FirstName" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="Adınız">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Soyadınız</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person text-primary"></i></span>
                                <input asp-for="LastName" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="Soyadınız">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">E-Posta Adresiniz</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-primary"></i></span>
                                <input asp-for="Email" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="E-posta">
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
                                Değişiklikleri Kaydet
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-bold text-muted py-3">
                                Vazgeç
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>