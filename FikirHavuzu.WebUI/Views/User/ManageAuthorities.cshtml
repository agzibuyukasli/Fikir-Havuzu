@model FikirHavuzu.WebUI.Models.UserAuthorityViewModel

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-shield-lock-fill"></i> @Model.UserName - Yetki Yönetimi</h4>
        </div>
        <div class="card-body">
            <p class="text-muted">Lütfen kullanıcıya tanımlamak istediğiniz yetkileri seçiniz.</p>
            <hr />
            
            <form asp-action="UpdateAuthorities" method="post">
                <input type="hidden" asp-for="UserId" />
                
                <div class="list-group mb-4">
                    @for (int i = 0; i < Model.Authorities.Count; i++)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div>
                                <input type="hidden" asp-for="@Model.Authorities[i].AuthorityId" />
                                <input type="hidden" asp-for="@Model.Authorities[i].AuthorityName" />
                                <h6 class="mb-0 text-dark">@Model.Authorities[i].AuthorityName</h6>
                                <small class="text-primary fw-bold">Kod: @Model.Authorities[i].AuthorityCode</small>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="@Model.Authorities[i].IsSelected" style="width: 3em; height: 1.5em;">
                            </div>
                        </div>
                    }
                </div>

                <div class="d-grid gap-2 d-md-block">
                    <button type="submit" class="btn btn-success px-5 shadow-sm">
                        <i class="bi bi-save"></i> Değişiklikleri Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>