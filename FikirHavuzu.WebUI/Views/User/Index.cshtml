@using FikirHavuzu.Entities
@model List<FikirHavuzu.Entities.User>

<style>
    .puan-toast {
        position: fixed;
        top: 100px;
        right: 30px;
        z-index: 9999;
        background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
        color: white;
        padding: 12px 25px;
        border-radius: 50px;
        min-width: 320px;
        box-shadow: 0 10px 30px rgba(9, 132, 227, 0.3);
        transition: all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        display: flex;
        align-items: center;
    }

    .puan-icon {
        font-size: 1.5rem;
        margin-right: 15px;
        background: rgba(255,255,255,0.2);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .fade-out {
        opacity: 0 !important;
        transform: translateX(100px);
    }
</style>

<div class="container-fluid px-md-5 mt-4 mb-5">
    @if (TempData["Message"] != null)
    {
        <div id="systemToast" class="puan-toast animate__animated animate__fadeInRight">
            <div class="puan-icon">
                <i class="bi bi-info-circle-fill"></i>
            </div>
            <div class="puan-text">
                <span class="d-block fw-bold text-uppercase" style="font-size: 0.65rem; opacity: 0.8; letter-spacing: 1px;">Sistem Mesajı</span>
                <span class="fw-bold">@TempData["Message"]</span>
            </div>
        </div>
    }
    <div class="row mb-5 mx-0">
        <div class="col-12 bg-white p-5 rounded-4 shadow-sm d-flex justify-content-between align-items-center border-bottom border-primary border-4">
            <div>
                <h1 class="display-3 fw-bold text-primary mb-2"><i class="bi bi-people-fill text-primary"></i> Personel Yönetimi</h1>
                <p class="fs-4 text-muted mb-0 fw-600">Sistemdeki tüm personel bilgilerini buradan yönetebilirsin.</p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success btn-lg px-5 rounded-pill shadow fw-bold py-3">
                    <i class="bi bi-person-plus-fill me-2"></i>Yeni Personel
                </a>
            }
        </div>
    </div>

    <div class="row mx-0">
        <div class="col-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="ps-4 py-4 fs-5">Ad Soyad</th>
                                <th class="py-4 fs-5">E-Posta</th>
                                <th class="py-4 fs-5 text-center">Durum</th>
                                <th class="py-4 fs-5 text-center">Puan</th>
                                <th class="py-4 fs-5 text-center">Rütbe</th>
                                <th class="pe-4 py-4 fs-5 text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null)
                            {
                                foreach (var item in Model)
                                {
                                    string rankClass = "bg-info";
                                    string rankName = "Yeni Fikirci";
                                    if (item.TotalScore >= 100) { rankName = "Usta Geliştirici"; rankClass = "bg-primary"; }
                                    else if (item.TotalScore >= 50) { rankName = "Fikir Mimarı"; rankClass = "bg-success"; }

                                    <tr class="user-row">
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-box me-3 bg-primary text-white text-uppercase">
                                                    @((item.FirstName?.Length > 0 ? item.FirstName[0].ToString() : "U"))@((item.LastName?.Length > 0 ? item.LastName[0].ToString() : ""))
                                                </div>
                                                <div>
                                                    <div class="fw-bold fs-4">@(item.FirstName ?? "İsimsiz") @(item.LastName ?? "Personel")</div>
                                                    @if (item.Role == "Admin") { <small class="badge bg-danger-subtle text-danger border border-danger rounded-pill" style="font-size:0.6rem; padding: 2px 8px;">YÖNETİCİ</small> }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 fs-5 text-lowercase text-muted">@(item.Email ?? "E-posta yok")</td>
                                        <td class="py-4 text-center">
                                            @if (item.IsActive) {
                                                <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2">Aktif</span>
                                            } else {
                                                <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-2">Pasif</span>
                                            }
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-warning text-dark fs-5 px-3 rounded-pill shadow-sm"><i class="bi bi-star-fill me-1"></i>@item.TotalScore</span>
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="badge @rankClass px-3 fs-6 rounded-pill shadow-sm">@rankName</span>
                                        </td>
                                        <td class="pe-4 py-4 text-end">
                                            <div class="d-flex justify-content-end gap-2 align-items-center">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-sm">
                                                    <i class="bi bi-info-circle-fill"></i> Detay
                                                </a>

                                                @if (User.IsInRole("Admin"))
                                                {
                                                    @if (item.Email != User.Identity.Name)
                                                    {
                                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm" title="Düzenle">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </a>

                                                        <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" style="display:inline;">
                                                            <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success") rounded-pill px-3 shadow-sm" title="@(item.IsActive ? "Pasif Yap" : "Aktif Yap")">
                                                                <i class="bi @(item.IsActive ? "bi-person-x-fill" : "bi-person-check-fill")"></i>
                                                                @(item.IsActive ? "Durdur" : "Aktifleştir")
                                                            </button>
                                                        </form>

                                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu personeli silmek istediğine emin misin?');" style="display:inline;">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm" title="Sil">
                                                                <i class="bi bi-trash-fill"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm" title="Düzenle">
                                                            <i class="bi bi-pencil-square"></i> Profilimi Düzenle
                                                        </a>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafd !important; font-family: 'Plus Jakarta Sans', sans-serif; }
    .fw-600 { font-weight: 600; }
    .avatar-box { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 800; box-shadow: 0 4px 10px rgba(9, 132, 227, 0.2); }
    .user-row { transition: all 0.2s; }
    .user-row:hover { background-color: rgba(9, 132, 227, 0.03) !important; }
    .table thead th { border: none; letter-spacing: 0.5px; text-transform: uppercase; }
    .btn-sm { font-weight: 600; padding: 0.4rem 0.8rem; }
    .badge { font-weight: 700; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var toast = document.getElementById('systemToast');
        if (toast) {
            setTimeout(function () {
                toast.classList.add('fade-out');
                
                setTimeout(function () {
                    toast.remove();
                }, 800); 
            }, 2000);
        }
    });


    function deleteIdea(id) {
        if (confirm('Bu fikri silmek istediğine emin misin?')) {
            $.post('/Idea/DeleteIdea/' + id, function () {
                $('#userProfileModal').modal('hide');
                location.reload(); 
            }).fail(function () {
                alert('Silme yetkiniz yok veya bir hata oluştu!');
            });
        }
    }

    $(document).ready(function () {
    });
</script>