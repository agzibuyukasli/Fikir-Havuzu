@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - Fikir Havuzu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #dff9fb 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 0;
            margin: 0;
        }

        body::before {
            content: "";
            position: absolute;
            width: 500px;
            height: 500px;
            background: var(--primary-gradient);
            border-radius: 50%;
            z-index: -1;
            bottom: -150px;
            left: -150px;
            opacity: 0.08;
        }

        .register-card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(9, 132, 227, 0.12);
            overflow: hidden;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            width: 100%;
            max-width: 650px;
        }

        .register-header {
            background: var(--primary-gradient);
            color: white;
            padding: 35px;
            text-align: center;
        }

        .register-header i {
            font-size: 2.5rem;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));
        }

        .register-header h3 {
            font-weight: 800;
            margin-top: 10px;
            letter-spacing: -0.5px;
        }

        .form-label {
            color: #2d3436;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .form-control {
            background-color: #f8f9fa !important;
            border: 2px solid #f8f9fa;
            padding: 10px 15px;
            border-radius: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background-color: #fff !important;
            border-color: #00cec9;
            box-shadow: 0 4px 12px rgba(0, 206, 201, 0.1);
        }

        .btn-register {
            background: var(--primary-gradient);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(9, 132, 227, 0.3);
            color: white;
        }

        .login-link {
            color: #0984e3;
            text-decoration: none;
            font-weight: 700;
        }

        .login-link:hover {
            color: #00cec9;
        }

        .input-group-text {
            background: #f8f9fa;
            border: 2px solid #f8f9fa;
            border-right: none;
            border-radius: 12px 0 0 12px;
            color: #0984e3;
        }
        
        .input-group .form-control {
            border-radius: 0 12px 12px 0;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center">
        <div class="card register-card">
            <div class="register-header">
                <i class="bi bi-person-plus-fill"></i>
                <h3>Yeni Hesap Oluştur</h3>
                <p class="small opacity-75 mb-0 fw-bold">Fikir Havuzu Ailesine Katılın</p>
            </div>
            
            <div class="card-body p-4 p-md-5">
                <form asp-action="Register" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ad</label>
                            <input type="text" name="FirstName" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Soyad</label>
                            <input type="text" name="LastName" class="form-control" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">T.C. Kimlik No</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                <input type="text" name="TCIdentityNumber" class="form-control" required maxlength="11" placeholder="11 Haneli">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sicil No</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-hash"></i></span>
                                <input type="text" name="RegistrationNumber" class="form-control" required placeholder="Sicil Numaranız">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">E-Posta</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-at"></i></span>
                            <input type="email" name="Email" class="form-control" required placeholder="ad.soyad@trtek.com">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Telefon Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input type="text" name="PhoneNumber" class="form-control" required placeholder="05xxxxxxxxx">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Şifre / Pin</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                            <input type="password" name="Password" class="form-control" required placeholder="Güçlü bir şifre belirleyin">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-register w-100 shadow-sm">
                        Kaydı Tamamla <i class="bi bi-check-circle-fill ms-1"></i>
                    </button>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">Zaten bir hesabınız var mı?</p>
                        <a asp-action="Login" class="login-link">Giriş Yap</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>