@{
    Layout = "_Layout";
    ViewData["Title"] = "Erişim Reddedildi";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5 animate__animated animate__zoomIn">
                <div class="mb-4 text-danger">
                    <i class="bi bi-shield-lock-fill" style="font-size: 6rem; filter: drop-shadow(0 10px 15px rgba(220, 53, 69, 0.2));"></i>
                </div>
                <h1 class="fw-800 text-dark mb-3">DUR</h1>
                <p class="text-muted fs-5 mb-4">
                    Bu alana giriş yetkiniz bulunmuyor. Personel yönetimi ve sistem ayarları sadece <strong>Yöneticiler</strong> içindir.
                </p>
                <div class="d-grid gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
                        <i class="bi bi-house-door-fill me-2"></i> Anasayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafd; }
    .fw-800 { font-weight: 800; }
    .btn-primary {
        background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
        border: none;
    }
</style>