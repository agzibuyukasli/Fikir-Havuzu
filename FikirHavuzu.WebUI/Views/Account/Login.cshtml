@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Fikir Havuzu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
          rel="stylesheet">

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
            --glass-bg: rgba(255, 255, 255, 0.9);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #dff9fb 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        body::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: var(--primary-gradient);
            border-radius: 50%;
            z-index: -1;
            top: -100px;
            right: -100px;
            opacity: 0.1;
        }

        .login-card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(9, 132, 227, 0.15);
            overflow: hidden;
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            width: 100%;
            max-width: 450px;
        }

        .login-header {
            background: var(--primary-gradient);
            color: white;
            padding: 40px 30px;
            text-align: center;
        }

        .login-header i {
            font-size: 3.5rem;
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.1));
        }

        .login-header h4 {
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-top: 15px;
        }

        .form-label {
            color: #2d3436;
            margin-bottom: 8px;
        }

        .input-group-text {
            background-color: #f8f9fa !important;
            border: 2px solid #f8f9fa;
            border-right: none;
            color: #0984e3;
            border-radius: 12px 0 0 12px;
        }

        .form-control {
            background-color: #f8f9fa !important;
            border: 2px solid #f8f9fa;
            padding: 12px;
            border-radius: 0 12px 12px 0;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background-color: #fff !important;
            border-color: #00cec9;
            box-shadow: none;
        }

        .btn-primary {
            background: var(--primary-gradient);
            border: none;
            padding: 14px;
            border-radius: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(9, 132, 227, 0.3);
            background: var(--primary-gradient);
        }

        .register-link {
            color: #0984e3;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s ease;
        }

        .register-link:hover {
            color: #00cec9;
        }

        .alert-danger {
            border-radius: 12px;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div class="container d-flex justify-content-center">
        <div class="card login-card">
            <div class="login-header">
                <i class="bi bi-lightbulb-fill"></i>
                <h4>IDEASS</h4>
                <p class="small opacity-75 mb-0 text-uppercase fw-bold" style="letter-spacing: 1px;">Fikir Havuzu Giriş
                </p>
            </div>

            <div class="card-body p-4 p-md-5">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 small shadow-sm mb-4 d-flex align-items-center">
                        <i class="bi bi-exclamation-octagon-fill me-2 fs-5"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-800 text-uppercase font-weight-bold">E-Posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-at-fill"></i></span>
                            <input type="email" name="email" class="form-control" required
                                   placeholder="ad.soyad@trtek.com">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-800 text-uppercase font-weight-bold">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock-fill"></i></span>
                            <input type="password" name="password" class="form-control" required placeholder="••••••••">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-4 shadow-sm">
                        Sisteme Bağlan <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>

                    <div class="text-center">
                        <p class="small text-muted mb-0">Henüz bir hesabınız yok mu?</p>
                        <a asp-action="Register" class="register-link">Hemen Ücretsiz Kayıt Ol</a>
                    </div>
                    @* Views/Account/Login.cshtml en alt kısımlar *@
                    <div class="mt-4 text-center border-top pt-3">
                        <p class="text-muted small">Yetkili personel misiniz?</p>
                        <a asp-action="AdminLogin" asp-controller="Account"
                               class="btn btn-sm btn-outline-dark rounded-pill px-4">
                            <i class="bi bi-shield-lock-fill me-1"></i> Yönetici Girişi
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>

</html>