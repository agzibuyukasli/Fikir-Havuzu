@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yönetici Girişi - Fikir Havuzu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
          rel="stylesheet">

    <style>
            body {
                background-color: #f0f7ff;
                font-family: 'Plus Jakarta Sans', sans-serif;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                background-image: radial-gradient(circle at 10% 20%, rgba(9, 132, 227, 0.05) 0%, transparent 20%),
                    radial-gradient(circle at 90% 80%, rgba(0, 206, 201, 0.05) 0%, transparent 20%);
                position: relative; 
                overflow: hidden; 
            }

            body::before, body::after {
                content: "";
                position: absolute;
                border-radius: 50%;
                z-index: -1;
                filter: blur(50px);
            }

            body::before {
                width: 500px;
                height: 500px;
                background: linear-gradient(135deg, #0984e3, #00cec9);
                top: -150px;
                right: -150px;
                opacity: 0.15;
            }

            body::after {
                width: 300px;
                height: 300px;
                background: #00cec9;
                bottom: -100px;
                left: -100px;
                opacity: 0.1;
            }

            .admin-container {
                width: 100%;
                max-width: 420px;
                background: white;
                border-radius: 2rem;
                overflow: hidden;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            }

            .admin-header {
                background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
                padding: 3.5rem 2rem;
                text-align: center;
                color: white;
                position: relative;
            }

            .admin-header::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 40px;
                background: white;
                clip-path: ellipse(50% 100% at 50% 100%);
            }

            .icon-box {
                width: 70px;
                height: 70px;
                background: rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(5px);
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 1rem;
                border: 2px solid rgba(255, 255, 255, 0.3);
            }

            .admin-body {
                padding: 2.5rem 3rem;
            }

            .form-label {
                font-weight: 800;
                font-size: 0.75rem;
                color: #adb5bd;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-left: 0.5rem;
            }

            .input-group-custom {
                position: relative;
                margin-bottom: 1.5rem;
            }

            .input-group-custom i {
                position: absolute;
                left: 1.2rem;
                top: 50%;
                transform: translateY(-50%);
                color: #0984e3;
                z-index: 10;
            }

            .form-control {
                background-color: #f8f9fa;
                border: 2px solid transparent;
                border-radius: 1rem;
                padding: 0.8rem 1rem 0.8rem 3rem;
                font-weight: 600;
                color: #2d3436;
                transition: all 0.3s;
            }

            .form-control:focus {
                background-color: white;
                border-color: #0984e3;
                box-shadow: 0 10px 20px rgba(9, 132, 227, 0.08);
                outline: none;
            }

            .btn-submit {
                background: linear-gradient(90deg, #0984e3, #00cec9);
                border: none;
                border-radius: 1rem;
                padding: 1rem;
                color: white;
                font-weight: 800;
                width: 100%;
                margin-top: 1rem;
                transition: all 0.3s;
                box-shadow: 0 8px 15px rgba(9, 132, 227, 0.2);
            }

            .btn-submit:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 25px rgba(9, 132, 227, 0.3);
                filter: brightness(1.05);
            }

            .footer-link {
                text-align: center;
                margin-top: 2rem;
            }

            .footer-link a {
                color: #adb5bd;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                transition: color 0.3s;
            }

            .footer-link a:hover {
                color: #0984e3;
            }
    </style>
</head>

<body>

    <div class="admin-container">
        @* Üst Kısım *@
        <div class="admin-header">
            <div class="icon-box">
                <i class="bi bi-shield-lock-fill fs-1"></i>
            </div>
            <h3 class="fw-800 mb-0">YÖNETİCİ GİRİŞİ</h3>
            <p class="small opacity-75 mb-0 fw-600">FİKİR HAVUZU Kontrol</p>
        </div>

        @* Form Kısmı *@
        <div class="admin-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 small py-2 rounded-4 text-center mb-4 fw-600">
                    <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="AdminLogin" method="post">
                <div class="mb-3">
                    <label class="form-label">E-POSTA ADRESİ</label>
                    <div class="input-group-custom">
                        <i class="bi bi-envelope-fill"></i>
                        <input type="email" name="email" class="form-control" placeholder="admin@fikirhavuzu.com"
                               required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">ŞİFRE</label>
                    <div class="input-group-custom">
                        <i class="bi bi-lock-fill"></i>
                        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-submit">
                    SİSTEME BAĞLAN <i class="bi bi-arrow-right-short ms-2 fs-5"></i>
                </button>

                <div class="footer-link">
                    <a asp-action="Login">
                        <i class="bi bi-person-circle me-1"></i> Personel Girişi
                    </a>
                </div>
            </form>
        </div>
    </div>

</body>

</html>