@model FikirHavuzu.Entities.Product

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h2 class="fw-800 text-primary mb-4"><i class="bi bi-pencil-square"></i> Ürünü Düzenle</h2>
                
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ürün Adı</label>
                        <input asp-for="Name" class="form-control rounded-3" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea asp-for="Description" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col">
                            <label class="form-label fw-bold">Fiyat (Puan)</label>
                            <input asp-for="Price" type="number" class="form-control rounded-3" required />
                        </div>
                        <div class="col">
                            <label class="form-label fw-bold">Stok</label>
                            <input asp-for="Stock" type="number" class="form-control rounded-3" required />
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 w-100 fw-bold">KAYDET</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 w-100">İPTAL</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>