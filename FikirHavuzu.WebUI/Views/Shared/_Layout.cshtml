<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fikir Havuzu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
          rel="stylesheet">

    <style>
        :root {
            --navbar-bg: #0984e3;
            --navbar-gradient: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);
            --accent-color: #ffffff;
            --bg-light: #f4f7f6;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-light);
        }

        .navbar {
            background: var(--navbar-gradient) !important;
            padding: 1.2rem 2rem;
            box-shadow: 0 4px 20px rgba(9, 132, 227, 0.2);
            border-bottom: none;
        }

        .navbar-brand {
            font-size: 2rem;
            font-weight: 800;
            color: #fff !important;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .nav-link {
            font-size: 1.15rem;
            font-weight: 600;
            color: rgba(14, 139, 31, 0.95) !important;
            margin: 0 10px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-link i {
            font-size: 1.3rem;
        }

        .nav-link:hover {
            color: #6965654d !important;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            transform: translateY(-2px);
        }

        .badge-new {
            font-size: 0.65rem;
            vertical-align: top;
            margin-left: -5px;
        }

        .user-profile-btn {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            padding: 10px 22px;
            border-radius: 50px;
            border: 1.5px solid rgba(255, 255, 255, 0.4);
            color: #ffffff !important;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .user-profile-btn .text-info {
            color: #ffffff !important;
        }

        .avatar-sm {
            background: white !important;
            color: #0984e3 !important;
        }

        .custom-tab {
            color: #4b5563 !important; 
            background-color: transparent !important;
            border: none !important;
            transition: all 0.3s ease-in-out;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .custom-tab.active {
            background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%) !important;
            color: white !important;
            box-shadow: 0 4px 10px rgba(9, 132, 227, 0.3);
        }

        .custom-tab:hover {
            background-color: rgba(9, 132, 227, 0.1) !important;
            color: #0984e3 !important;
        }
        .hover-scale:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }
        .transition-all {
            transition: all 0.3s ease;
        }
        .fw-800 { font-weight: 800; }

        .nav-link {
            color: #ffffff !important;
            transition: 0.3s all;
        }

        .nav-link:hover {
            color: #ffffff !important;
            transform: scale(1.1);
        }
        .custom-tab:hover:not(.active) {
            background-color: #e9ecef !important;
            color: #0984e3 !important;
        }

        .nav-link i {
            font-size: 1.5rem;
            vertical-align: middle;
        }

        .hover-scale-up:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
            box-shadow: 0 10px 20px ffffff(9, 132, 227, 0.3) !important;
        }

        .nav-link.active {
            border-bottom: 3px solid #ffffff;
        }
        .nav-item {
            /*background-color: #e3df09;*/ 
        }
        .modal-header {
            z-index: 1;
            padding-bottom: 2rem !important;
        }
        .custom-switch:checked {
        background-color: #0984e3 !important;
        border-color: #0984e3 !important;
        }

        .hover-up:hover {
            transform: translateY(-2px);
            background-color: #0984e3 !important;
            color: white !important;
        }

        .tab-pane.active {
            display: block !important;
            opacity: 1 !important;
        }
        .modal-body {
            overflow-y: auto;
        }
        .custom-tab {
        color: #6c757d  !important;
        background-color: transparent !important;
        border: 1px solid #dee2e6 !important;
        transition: all 0.3s;
        }

        .custom-tab.active {
            background-color: #0984e3 !important;
            color: white !important;
            border-color: #0984e3 !important;
            box-shadow: 0 4px 10px rgba(9, 132, 227, 0.2);
        }

         .custom-tab:hover:not(.active) {
            border-color: #0984e3  !important;
            color: #0984e3  !important;
            
        } 
        #marketPanel {
            transition: all 0.3s ease-in-out;
        }
        .transition-hover:hover {
            transform: translateY(-2px);
            background-color: #fff !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
        }
        #marketPanel::-webkit-scrollbar {
            width: 5px;
        }
        #marketPanel::-webkit-scrollbar-thumb {
            background: #FFD700;
            border-radius: 10px;
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top mb-0">
            <div class="container-fluid px-md-5">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightbulb-fill text-white me-2"></i> IDE<span style="color: #dff9fb;">ASS</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto gap-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fs-4 fw-bold px-3 py-2" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-2 text-light"></i>Anasayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fs-4 fw-bold px-3 py-2" asp-controller="User" asp-action="Index">
                                <i class="bi bi-people-fill me-2 text-light"></i>Personel
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fs-4 fw-bold px-3 py-2" asp-controller="Idea" asp-action="Index">
                                <i class="bi bi-lightbulb-fill me-2 text-light"></i>Fikirler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fs-4 fw-bold px-3 py-2" asp-controller="Market" asp-action="Index">
                                <i class="bi bi-bag-heart-fill me-2 text-light"></i>Market
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex align-items-center gap-4">
                                <div id="userScoreContainer" class="d-flex align-items-center bg-warning text-dark px-4 rounded-pill shadow ...">
                                    <i class="bi bi-gem text-dark me-2 fw-bold" style="-webkit-text-stroke: 1px;"></i>
                                    <span id="navUserScore" class="fw-bold" style="font-size: 1.4rem;">
                                        0
                                    </span>
                                    <span class="fw-bold text-uppercase ms-2" style="font-size: 1.4rem;">Puan</span>
                                </div>

                                <button type="button"
                                    class="btn rounded-pill px-3 d-flex align-items-center shadow border-0 hover-scale-up"
                                    style="min-height: 55px; width: auto; max-width: 250px; background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%) !important; color: white; white-space: nowrap; overflow: hidden;"
                                    data-bs-toggle="modal" data-bs-target="#userProfileModal">

                                <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm flex-shrink-0"
                                    style="width: 38px; height: 38px; font-size: 1.1rem; font-weight: 900;">
                                    @(User.Identity.Name.Substring(0, 1).ToUpper())
                                </div>

                                <span class="fw-800 fs-5 text-truncate" style="max-width: 150px;">
                                    @User.Identity.Name
                                </span>

                                <i class="bi bi-chevron-down ms-2 fs-6 opacity-75 flex-shrink-0"></i>
                            </button>

                            </div>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container text-center">
            <div class="mb-2">
                <a asp-controller="Home" asp-action="Yardim" class="text-decoration-none text-muted mx-2 small">Yardım</a>
                <a asp-controller="Home" asp-action="Destek" class="text-decoration-none text-muted mx-2 small">Destek</a>
                <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Gizlilik</a>
            </div>
            <p class="text-muted small mb-0">&copy; 2026 - <strong>IDEASS</strong> Fikir Platformu</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

<script>
    $(document).ready(function () {
        $('#userProfileModal').on('show.bs.modal', function () {
            $('#userIdeasContent').html('<div class="text-center py-5"><div class="spinner-grow text-primary" role="status"></div><p class="mt-2 text-muted">Yükleniyor...</p></div>');

            $.get('/Idea/GetUserIdeas', function (data) {
                $('#userIdeasContent').html(data);
            }).fail(function () {
                $('#userIdeasContent').html('<p class="text-danger text-center py-4"><i class="bi bi-exclamation-triangle me-2"></i>Veriler şu an yüklenemedi.</p>');
            });
        });
    });
</script>

    <div class="modal fade" id="userProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            
            <div class="modal-header border-0 p-4 text-white d-flex justify-content-between align-items-center"
                 style="background: linear-gradient(135deg, #0984e3 0%, #00cec9 100%);">
                <div class="d-flex align-items-center">
                    <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm me-3"
                         style="width: 45px; height: 45px; font-weight: 800;">
                        @(User.Identity.Name.Substring(0, 1).ToUpper())
                    </div>
                    <h5 class="fw-bold mb-0">@User.Identity.Name</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-0 bg-white" style="min-height: 500px;">

                <div class="p-3 shadow-sm border-bottom text-secondary" style="background-color: #f1f8f8;">
                    <ul class="nav nav-pills nav-fill gap-3" id="profileTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active rounded-pill fw-bold py-2 custom-tab" id="ideas-tab" 
                                    data-bs-toggle="pill" data-bs-target="#ideasContent" type="button" role="tab">
                                <i class="bi bi-lightbulb me-2"></i> Fikirlerim
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link rounded-pill fw-bold py-2 custom-tab" id="settings-tab" 
                                    data-bs-toggle="pill" data-bs-target="#settingsContent" type="button" role="tab">
                                <i class="bi bi-bar-chart-line-fill me-2"></i> İstatistikler
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="tab-content" id="profileTabsContent">

                    <div class="tab-pane fade show active p-4" id="ideasContent" role="tabpanel" aria-labelledby="ideas-tab">
                        <div id="userIdeasContent" class="overflow-auto custom-scroll" style="max-height: 400px;">
                        </div>
                    </div>

                    <div class="tab-content" id="profileTabsContent">
    
                    <div class="tab-pane fade show active p-4" id="ideasContent" role="tabpanel">
                        <div id="userIdeasContent"></div>
                    </div>

                    <div class="tab-pane fade p-4" id="settingsContent" role="tabpanel">
                        
                        <div class="stats-box p-3 rounded-4 mb-4" style="background: rgba(9, 132, 227, 0.05);">
                            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-graph-up me-2"></i>Performans Analizi</h6>
                            <div class="progress rounded-pill mb-2" style="height: 12px; background: #e9ecef;">
                                <div id="statsProgress" class="progress-bar" style="width: 0%; background: linear-gradient(90deg, #0984e3, #00cec9);"></div>
                            </div>
                            <small id="statsRateText" class="text-muted">Analiz ediliyor...</small>
                        </div>

                        <div class="list-group list-group-flush">
                            <div class="list-group-item border-0 d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                                <div class="text-dark fw-600">Toplam Paylaşım</div>
                                <span id="statsTotalIdeas" class="badge bg-primary rounded-pill px-3">0</span>
                            </div>
                            <div class="list-group-item border-0 d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                                <div class="text-dark fw-600">Onaylanan Fikirler</div>
                                <span id="statsApprovedIdeas" class="badge bg-success rounded-pill px-3">0</span>
                            </div>
                            <div class="list-group-item border-0 d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                                <div class="text-dark fw-600">Toplam Puanın</div>
                                <span id="statsUserScore" class="badge bg-warning text-dark rounded-pill px-3 shadow-sm">0 Puan</span>
                            </div>
                        </div>
                    </div>
                </div>

                </div>
            </div>

            <button type="button" class="btn w-100 mb-2 rounded-pill shadow-sm py-2 fw-bold" 
                    style="background: linear-gradient(45deg, #FFD700, #FFA500); color: #fff; border: none;"
                    onclick="toggleMarketPanel()">
                <i class="bi bi-cart-check-fill me-2"></i> Marketten Aldıklarım
            </button>

            <div class="modal-footer border-0 p-4 pt-0">
                <a class="btn btn-danger w-100 rounded-pill fw-bold" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right me-2"></i> Güvenli Çıkış Yap
                </a>
            </div>
            <div id="marketPanel" class="position-absolute top-0 start-0 w-100 h-100 bg-white rounded-4 shadow-lg p-3" 
                style="display: none; z-index: 1055; overflow-y: auto;">
                            
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-bag-heart-fill text-warning me-2"></i>Envanterim</h5>
                    <button type="button" class="btn-close shadow-none" onclick="toggleMarketPanel()"></button>
                </div>

                <div id="marketItemsList" class="market-items">                   
                    <div class="text-center mt-5 text-muted">
                        <i class="bi bi-cart-x display-4"></i>
                        <p class="mt-2">Henüz bir ürün almadın.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>

</html>

<script>
$(document).ready(function() {
    $('#profileTabs button').on('click', function (e) {
        e.preventDefault();
        $(this).tab('show');
        console.log("Sekme değiştirildi: " + $(this).attr('data-bs-target'));
    });
});

$(document).ready(function() {
    updateScore();

    function updateScore() {
        $.get('/User/GetUserScore', function(data) {
            $('#navUserScore').text(data);
            console.log("Puan güncellendi: " + data);
        });
    }
});

    $(document).ready(function () {
        $('#userProfileModal').on('show.bs.modal', function () {

            $.get('/Idea/GetUserIdeas', function (data) {
                $('#userIdeasContent').html(data);
            });

            $.get('/Idea/GetUserStats', function (stats) {
                $('#statsProgress').css('width', stats.rate + '%');
                $('#statsRateText').html('Fikirlerinin <b>%' + stats.rate + '</b> kadarı onaylandı.');

                $('#statsTotalIdeas').text(stats.total);
                $('#statsApprovedIdeas').text(stats.approved);
                $('#statsUserScore').html('<i class="bi bi-star-fill me-1"></i> ' + stats.score + ' Puan');
            });
        });
    });

function toggleMarketPanel() {
    console.log("Fonksiyon tetiklendi!");
    var panel = document.getElementById('marketPanel');
    var listContainer = document.getElementById('marketItemsList');

    if (!panel) {
        console.error("marketPanel ID'li div bulunamadı!");
        return;
    }

    if (panel.style.display === "none" || panel.style.display === "") {
        panel.style.display = "block";
        
        fetch('/User/GetUserPurchasedItems')
            .then(response => response.json())
            .then(data => {
                console.log("Gelen veriler:", data);
                listContainer.innerHTML = '';
                
                if (data.length === 0) {
                    listContainer.innerHTML = '<div class="text-center py-5 text-muted"><i class="bi bi-cart-x display-1 opacity-25"></i><p class="mt-3">Henüz bir ürün satın almadınız.</p></div>';
                } else {
                    data.forEach(item => {
                        listContainer.innerHTML += `
                            <div class="d-flex align-items-center p-3 mb-3 rounded-4 border-start border-5 border-warning shadow-sm bg-light">
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold text-dark">${item.itemName}</h6>
                                    <small class="text-muted"><i class="bi bi-calendar-event me-1"></i>${item.date}</small>
                                </div>
                                <div class="badge rounded-pill bg-warning text-dark px-3 py-2 fw-bold">${item.price} P</div>
                            </div>`;
                    });
                }
            })
            .catch(error => console.error('Fetch Hatası:', error));
    } else {
        panel.style.display = "none";
    }
}
</script>